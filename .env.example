# Copy to `.env` (git-ignored) and fill in real values.
# Supabase CLI reads these when running `npx supabase start`.

# Google OAuth (from https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI (set in Google Console): http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
